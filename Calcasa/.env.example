# Calcasa Desktoptaxatie
# Kopieer dit bestand naar .env en vul je gegevens in

# Optie 1: Bearer token uit browser (voor discovery)
# Log in op app.desktoptaxatie.nl → DevTools → Network tab
# Zoek een request naar api.calcasa.nl → kopieer Authorization header waarde (zonder "Bearer ")
CALCASA_BEARER_TOKEN=eyJ...

# Optie 2: Portal credentials (voor later, automatische login)
CALCASA_USERNAME=your_username
CALCASA_PASSWORD=your_password
